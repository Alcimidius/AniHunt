{
    "name": "anihunt",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "dev:backend": "node --watch --env-file=.env apps/backend/app.js",
        "dev:frontend": "npm run dev apps/frontend",
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "lint": "eslint packages/"
    },
    "devDependencies": {
        "eslint": "^9.0.0"
    },
    "dependencies": {
        "@huggingface/inference": "^4.13.15",
        "@huggingface/transformers": "^4.0.1",
        "@langchain/core": "^1.1.39",
        "@langchain/nomic": "^1.0.1",
        "@langchain/ollama": "^1.2.6",
        "@langchain/qdrant": "^1.0.1",
        "@xenova/transformers": "^2.17.2",
        "concurrently": "^9.2.1",
        "groq-sdk": "^1.1.2",
        "langchain": "^1.3.1",
        "sanitize-html": "^2.17.2"
    }
}
